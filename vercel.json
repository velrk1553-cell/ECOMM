{
  "buildCommand": "cd frontend/amercereactjs && npm install && npm run build",
  "outputDirectory": "frontend/amercereactjs/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/proxy"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
